# Administrative Credentials
# WARNING: Do not use 'admin/admin' in production. 
# Rotate these values frequently.
ADMIN_USER=[YOUR_OPERATOR_USERNAME]
ADMIN_PASS=[YOUR_SECURE_PASSWORD]

# Server Configuration
PORT=3000

# Security Configuration
# CRITICAL: Replace with a long, random string (e.g., openssl rand -base64 32)
JWT_SECRET=[REPLACE_WITH_SECURE_RANDOM_SECRET]
